{
  "manifest_version": 3,
  "name": "Voxium",
  "version": "3.0.0",
  "description": "Navigate any website with your voice. Persists when popup closes. AI voice responses. Summarize, explain, translate any page.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "bookmarks",
    "windows",
    "sessions",
    "scripting",
    "contextMenus",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Voxium v3 — Voice Navigation"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
